# ── Copy this file to .env and fill in your real values ──────────────────────
# NEVER commit .env — only .env.example is tracked by git

# Supabase PostgreSQL connection (Project Settings → Database → Connection string)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Groq LLM Inference API key (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Pinecone (legacy — not required for pgvector branch)
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=legal-frameworks-index

# Optional: Discord webhook for regulatory drift alerts
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

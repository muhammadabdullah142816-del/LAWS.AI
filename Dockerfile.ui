FROM python:3.10-slim

WORKDIR /app

# Pre-install the UI dependencies inside the container to bypass local network issues
RUN pip install --no-cache-dir streamlit groq pinecone-client supabase

# Copy the entire project, including the .streamlit/secrets.toml folder
COPY . /app

EXPOSE 8501

# Start the Streamlit server
CMD ["streamlit", "run", "app.py", "--server.port=8501", "--server.address=0.0.0.0"]
